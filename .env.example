########################################
# Core application settings
########################################
NODE_ENV=production
PORT=4000
CLIENT_ORIGIN=*
LOG_LEVEL=info

########################################
# Database (MongoDB)
########################################
# Hostnames like "mongo" only work INSIDE Docker Compose (the api container).
#
# Option A — API runs in Docker (`docker compose` api service): use service name (compose also injects this).
MONGODB_URI=mongodb://mongo:27017/nepzo
#
# Option B — API runs ON THE HOST (PM2, `npm run dev`) while Mongo runs in Docker with port 27017 published:
# MONGODB_URI=mongodb://127.0.0.1:27017/nepzo
#
# Option C — MongoDB Atlas (no local Mongo):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/nepzo?retryWrites=true&w=majority

########################################
# Encryption (generate new key for production!)
########################################
ENCRYPTION_KEY=YOUR_32_BYTE_HEX_KEY_HERE

########################################
# Authentication
########################################
JWT_SECRET=YOUR_STRONG_JWT_SECRET_HERE
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=840891196284-kijebscungi0j644gvvlr5eemritt10l.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=840891196284-44imhgf3jjqsp0v8sq716vaam5jp7h69.apps.googleusercontent.com

########################################
# MinIO (media storage)
########################################
# "minio" only resolves inside Compose. For PM2 / npm run dev on the host, use: MINIO_ENDPOINT=127.0.0.1
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_THIS_STRONG_PASSWORD
MINIO_BUCKET=nepzo-media

########################################
# AWS S3 (media backup - required by app)
########################################
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
S3_BUCKET=your-s3-bucket

########################################
# Cache (Redis)
########################################
CACHE_ENABLED=true
# "redis" only inside Compose. For PM2 / npm run dev on the host: CACHE_HOST=127.0.0.1
CACHE_HOST=redis
CACHE_PORT=6379

########################################
# WebRTC TURN (required for calls on mobile data / restrictive networks)
########################################
# See TURN_SETUP.md and DEPLOYMENT_AWS.md (WebRTC on AWS).
#
# TURN_URL must reach coturn on THIS EC2 instance, UDP+TCP port 3478. HTTPS via Nginx does not carry TURN.
# If the API hostname is behind Cloudflare "proxied" (orange cloud), use the Elastic IP in TURN_URL instead.
#
# AWS: set TURN_EXTERNAL_IP (Elastic IP) + TURN_PRIVATE_IP (e.g. 172.31.x.x from: hostname -I on EC2)
#      so relay candidates advertise the correct public address.
TURN_URL=turn:13.127.202.45:3478
TURN_USERNAME=nepzo_turn
TURN_CREDENTIAL=CHANGE_ME_STRONG_SECRET
TURN_REALM=nepzo.rentoranepal.com
TURN_EXTERNAL_IP=13.127.202.45
TURN_PRIVATE_IP=YOUR_EC2_PRIVATE_IP

########################################
# Firebase (push notifications - required for FCM)
########################################
# Option A: File path (cert must exist at src/certs/ - copy via SCP, see DEPLOYMENT_AWS.md)
FIREBASE_SERVICE_ACCOUNT_PATH=./src/certs/nepzo-21619-firebase-adminsdk.json

# Option B: Base64 (if not using file - encode: base64 -w 0 nepzo-21619-firebase-adminsdk.json)
# FIREBASE_SERVICE_ACCOUNT_JSON_B64=

########################################
# Push Notifications (Expo)
########################################
EXPO_ACCESS_TOKEN=your-expo-access-token
